function ToastContainer({ toasts, onClose }) {
  const icons = { success: "✓", error: "✕", warning: "!", info: "↗" };
  return (
    <div className="toast-wrap">
      {toasts.map(t => (
        <div key={t.id} className={`toast toast-${t.type}`} onClick={() => onClose(t.id)}>
          <div className="toast-icon">{icons[t.type] || "i"}</div>
          <div className="flex-1">
            <div>{t.title}</div>
            {t.message && <div className="toast-msg">{t.message}</div>}
          </div>
          <div className="toast-close">×</div>
        </div>
      ))}
    </div>
  );
}

function useToast() {
  const [toasts, setToasts] = useState([]);
  const addToast = useCallback((t) => {
    const id = Date.now();
    setToasts(p => [...p, { ...t, id }]);
    setTimeout(() => setToasts(p => p.filter(x => x.id !== id)), 4500);
  }, []);
  const removeToast = useCallback((id) => setToasts(p => p.filter(x => x.id !== id)), []);
  return { toasts, addToast, removeToast };
}

