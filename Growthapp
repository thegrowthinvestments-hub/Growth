const calcDecemberBalance = (monthlyAmount) => {
  const rate = getGrowthRate(monthlyAmount) / 100;
  const startMonth = new Date().getMonth();
  let balance = 0;
  for (let i = 0; i <= 11 - startMonth; i++) balance = (balance + monthlyAmount) * (1 + rate);
  return balance;
};
const PAYOUT_DATE = new Date("2026-12-15T00:00:00");
const getCountdown = () => {
  const diff = PAYOUT_DATE - new Date();
  if (diff <= 0) return { days: 0, hours: 0, minutes: 0, seconds: 0, unlocked: true };
  return {
    days: Math.floor(diff / 86400000),
    hours: Math.floor((diff % 86400000) / 3600000),
    minutes: Math.floor((diff % 3600000) / 60000),
    seconds: Math.floor((diff % 60000) / 1000),
    unlocked: false,
  };
};

