function AnalyticsChart({ monthlyAmount }) {
  const [tooltip, setTooltip] = useState(null);
  const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  const rate = getGrowthRate(monthlyAmount) / 100;
  const data = months.map((m, i) => {
    let balance = 0;
    for (let j = 0; j <= i; j++) balance = (balance + monthlyAmount) * (1 + rate);
    return { month: m, deposit: monthlyAmount, balance: Math.round(balance) };
  });
  const maxB = Math.max(...data.map(d => d.balance));
  const W = 700, H = 230, P = { t: 20, r: 16, b: 40, l: 64 };
  const iW = W - P.l - P.r, iH = H - P.t - P.b;
  const xPos = i => P.l + (i / 11) * iW;
  const yPos = v => P.t + iH - (v / maxB) * iH;
  const bW = iW / 12 * 0.45;
  const xBar = i => P.l + (i / 12) * iW + (iW / 12) * 0.27;
  const lp = data.map((d, i) => `${i === 0 ? "M" : "L"}${xPos(i)},${yPos(d.balance)}`).join(" ");

  return (
    <div style={{ position: "relative" }}>
      {tooltip && (
        <div className="chart-tooltip" style={{ left: tooltip.x, top: tooltip.y }}>
          <div style={{ color: "var(--teal-dark)", marginBottom: 4 }}>{tooltip.month} 2026</div>
          <div>Deposit: {fmt(tooltip.deposit)}</div>
          <div>Balance: {fmt(tooltip.balance)}</div>
        </div>
      )}
      <svg viewBox={`0 0 ${W} ${H}`} className="chart-svg">
        {[0, .25, .5, .75, 1].map(t => {
          const y = P.t + iH * (1 - t);
          return (
            <g key={t}>
              <line x1={P.l} y1={y} x2={W - P.r} y2={y} stroke="rgba(0,0,0,0.05)" strokeWidth="1" strokeDasharray="4 4" />
              <text x={P.l - 8} y={y + 4} fill="var(--text3)" fontSize="10" textAnchor="end" fontFamily="Nunito" fontWeight="700">{fmt(maxB * t)}</text>
            </g>
          );
        })}

        {/* Bar area top shadow */}
        <defs>
          <linearGradient id="barGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stopColor="#3498db" stopOpacity=".55" />
            <stop offset="100%" stopColor="#3498db" stopOpacity=".15" />
          </linearGradient>
          <linearGradient id="lineGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stopColor="var(--teal)" stopOpacity=".2" />
            <stop offset="100%" stopColor="var(--teal)" stopOpacity="0" />
          </linearGradient>
          <filter id="barShadow">
            <feDropShadow dx="0" dy="2" stdDeviation="3" floodColor="#3498db" floodOpacity="0.2" />
          </filter>
        </defs>

        {data.map((d, i) => (
          <rect key={i} x={xBar(i)} y={yPos(d.deposit)} width={bW} height={iH - (yPos(d.deposit) - P.t)}
            fill="url(#barGrad)" rx={5} filter="url(#barShadow)"
            onMouseMove={e => { const r = e.currentTarget.closest("svg").getBoundingClientRect(); setTooltip({ x: e.clientX - r.left, y: e.clientY - r.top, ...d }); }}
            onMouseLeave={() => setTooltip(null)} style={{ cursor: "pointer" }}
          />
        ))}

        <path d={`${lp} L${xPos(11)},${P.t + iH} L${xPos(0)},${P.t + iH} Z`} fill="url(#lineGrad)" />
        <path d={lp} fill="none" stroke="var(--teal)" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" />
        {data.map((d, i) => (
