          { label: "Total Users", value: "247", icon: "👥", color: "#3498db" },
          { label: "Total Invested", value: fmt(1847320), icon: "💰", color: "var(--teal-dark)" },
          { label: "Monthly Deposits", value: fmt(342800), icon: "📈", color: "#1d9954" },
          { label: "Withdrawals", value: "0", icon: "📤", color: "#9b59b6" },
          { label: "Penalties", value: "12", icon: "⚠️", color: "#c0392b" },
        ].map((s, i) => (
          <div key={i} className="nm-card" style={{ textAlign: "center" }}>
            <div style={{ fontSize: 28, marginBottom: 10 }}>{s.icon}</div>
            <div style={{ fontSize: 26, fontWeight: 900, color: s.color }}>{s.value}</div>
            <div className="text-xs text-muted" style={{ marginTop: 4, textTransform: "uppercase", letterSpacing: ".8px" }}>{s.label}</div>
          </div>
        ))}
      </div>

      <div className="nm-card">
        <div style={{ fontWeight: 800, fontSize: 15, marginBottom: 16 }}>Investor List</div>
        <div className="table-wrap">
          <table>
            <thead><tr><th>#</th><th>Name</th><th>Balance</th><th>Goal %</th><th>Status</th></tr></thead>
            <tbody>
              {DEMO_LEADERBOARD.slice(0, 12).map((u, i) => (
                <tr key={u.id}>
                  <td style={{ color: "var(--text3)", fontWeight: 700 }}>{i + 1}</td>
                  <td style={{ fontWeight: 700 }}>{u.name}</td>
                  <td style={{ color: "var(--teal-dark)", fontWeight: 900 }}>{fmt(u.balance)}</td>
                  <td style={{ color: "#1d9954", fontWeight: 800 }}>{u.completion}%</td>
                  <td><StatusBadge status="success" /></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <div className="footer">Payments powered by <strong>Yoco</strong></div>
    </div>
  );
}

// ============================================================
// MAIN APP
// ============================================================
export default function App() {
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(true);
  const [page, setPage] = useState("dashboard");
  const [payments, setPayments] = useState(DEMO_PAYMENTS);
  const { toasts, addToast, removeToast } = useToast();

  useEffect(() => {
    const cached = sb.auth.getUser();
    if (cached) setUser(cached);
    setLoading(false);
  }, []);

  const handleLogout = () => { sb.auth.signOut(); setUser(null); setPage("dashboard"); };

  if (loading) return (
    <>
      <style>{CSS}</style>
      <div style={{ minHeight: "100vh", display: "flex", alignItems: "center", justifyContent: "center", background: "var(--bg)", fontFamily: "Nunito, sans-serif" }}>
        <div style={{ textAlign: "center" }}>
          <div style={{ fontSize: 52, marginBottom: 16 }}>🎄</div>
          <div style={{ fontSize: 16, fontWeight: 800, color: "var(--text)" }}>Loading Holiday Savings...</div>
        </div>
      </div>
    </>
  );

  return (
    <>
      <style>{CSS}</style>
      {!user ? (
        <AuthPage onAuth={setUser} />
      ) : (
        <div className="app">
          {page === "dashboard"   && <DashboardPage user={user} payments={payments} onNav={setPage} />}
          {page === "invest"      && <InvestPage user={user} payments={payments} setPayments={setPayments} addToast={addToast} />}
          {page === "analytics"   && <AnalyticsPage user={user} payments={payments} />}
          {page === "leaderboard" && <LeaderboardPage />}
          {page === "withdraw"    && <WithdrawPage user={user} payments={payments} />}
          {page === "settings"    && <SettingsPage user={user} onLogout={handleLogout} />}
          {page === "admin"       && <AdminPage />}
          <FloatingNav active={page} onNav={setPage} isAdmin={user?.email?.includes("admin")} />
        </div>
      )}
      <ToastContainer toasts={toasts} onClose={removeToast} />
    </>
  );
}
