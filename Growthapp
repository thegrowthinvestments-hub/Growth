const VERIFY_PAYMENT_URL = `${SUPABASE_URL}/functions/v1/verify-payment`;

const sb = {
  auth: {
    signIn: async ({ email, password }) => {
      const r = await fetch(`${SUPABASE_URL}/auth/v1/token?grant_type=password`, {
        method: "POST", headers: { "Content-Type": "application/json", apikey: SUPABASE_ANON_KEY },
        body: JSON.stringify({ email, password }),
      }).catch(() => null);
      if (!r) return { data: null, error: { message: "Network error" } };
      const d = await r.json();
      if (!d.access_token) return { data: null, error: { message: d.error_description || "Invalid credentials" } };
      localStorage.setItem("sb_token", d.access_token);
      localStorage.setItem("sb_user", JSON.stringify(d.user));
      return { data: d, error: null };
    },
    signUp: async ({ email, password, options }) => {
      const r = await fetch(`${SUPABASE_URL}/auth/v1/signup`, {
        method: "POST", headers: { "Content-Type": "application/json", apikey: SUPABASE_ANON_KEY },
        body: JSON.stringify({ email, password, data: options?.data }),
      }).catch(() => null);
      if (!r) return { data: null, error: { message: "Network error" } };
      const d = await r.json();
      if (d.error || d.msg) return { data: null, error: { message: d.error_description || d.msg || "Signup failed" } };
      return { data: d, error: null };
    },
    signOut: () => { localStorage.removeItem("sb_token"); localStorage.removeItem("sb_user"); },
    getUser: () => { const u = localStorage.getItem("sb_user"); return u ? JSON.parse(u) : null; },
  },
};

const verifyPayment = async ({ checkoutId, userId, amount, month }) => {
  try {
    const res = await fetch(VERIFY_PAYMENT_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json", Authorization: `Bearer ${localStorage.getItem("sb_token")}`, apikey: SUPABASE_ANON_KEY },
      body: JSON.stringify({ checkoutId, userId, amount, month }),
    });
    return await res.json();
  } catch { return { ok: false, error: "Network error" }; }
};

