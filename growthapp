function AnalyticsChart({ monthlyAmount }) {
  const [tooltip, setTooltip] = useState(null);
  const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  const rate = getGrowthRate(monthlyAmount) / 100;
  const data = months.map((m, i) => {
    let balance = 0;
    for (let j = 0; j <= i; j++) balance = (balance + monthlyAmount) * (1 + rate);
    return { month: m, deposit: monthlyAmount, balance: Math.round(balance) };
  });
  const maxB = Math.max(...data.map(d => d.balance));
  const W = 700, H = 220, P = { t: 16, r: 16, b: 36, l: 60 };
  const iW = W - P.l - P.r, iH = H - P.t - P.b;
  const xPos = i => P.l + (i / 11) * iW;
  const yPos = v => P.t + iH - (v / maxB) * iH;
  const bW = iW / 12 * 0.42;
  const xBar = i => P.l + (i / 12) * iW + (iW / 12) * 0.29;
  const lp = data.map((d, i) => `${i === 0 ? "M" : "L"}${xPos(i)},${yPos(d.balance)}`).join(" ");

  return (
    <div style={{ position: "relative" }}>
      {tooltip && (
        <div style={{ position: "absolute", background: "rgba(255,255,255,0.97)", border: "1px solid var(--divider)", borderRadius: 10, padding: "8px 13px", fontSize: 12, fontWeight: 500, color: "var(--text1)", boxShadow: "var(--shadow-md)", pointerEvents: "none", transform: "translate(-50%,-115%)", left: tooltip.x, top: tooltip.y, whiteSpace: "nowrap", zIndex: 10 }}>
          <div style={{ color: "var(--teal-dk)", marginBottom: 3, fontWeight: 600 }}>{tooltip.month} 2026</div>
          <div style={{ color: "var(--text3)" }}>Deposit: <span style={{ color: "var(--text1)", fontWeight: 600 }}>{fmt(tooltip.deposit)}</span></div>
          <div style={{ color: "var(--text3)" }}>Balance: <span style={{ color: "var(--teal-dk)", fontWeight: 700 }}>{fmt(tooltip.balance)}</span></div>
        </div>
      )}
      <svg viewBox={`0 0 ${W} ${H}`} style={{ width: "100%", overflow: "visible" }}>
        <defs>
          <linearGradient id="barG" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stopColor="var(--blue)" stopOpacity=".35" />
            <stop offset="100%" stopColor="var(--blue)" stopOpacity=".08" />
          </linearGradient>
          <linearGradient id="areaG" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stopColor="var(--teal)" stopOpacity=".18" />
            <stop offset="100%" stopColor="var(--teal)" stopOpacity="0" />
          </linearGradient>
        </defs>
        {[0,.25,.5,.75,1].map(t => {
          const y = P.t + iH * (1 - t);
          return <g key={t}>
            <line x1={P.l} y1={y} x2={W-P.r} y2={y} stroke="var(--divider)" strokeWidth="1" strokeDasharray="3 3"/>
            <text x={P.l-8} y={y+4} fill="var(--text4)" fontSize="9" textAnchor="end" fontFamily="Inter" fontWeight="500">{fmt(maxB*t)}</text>
          </g>;
        })}
        {data.map((d, i) => (
          <rect key={i} x={xBar(i)} y={yPos(d.deposit)} width={bW} height={iH-(yPos(d.deposit)-P.t)}
            fill="url(#barG)" rx={4}
            onMouseMove={e => { const r = e.currentTarget.closest("svg").getBoundingClientRect(); setTooltip({ x: e.clientX-r.left, y: e.clientY-r.top, ...d }); }}
            onMouseLeave={() => setTooltip(null)} style={{ cursor: "pointer" }}
          />
        ))}
        <path d={`${lp} L${xPos(11)},${P.t+iH} L${xPos(0)},${P.t+iH} Z`} fill="url(#areaG)" />
        <path d={lp} fill="none" stroke="var(--teal)" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" />
        {data.map((d, i) => (
          <circle key={i} cx={xPos(i)} cy={yPos(d.balance)} r={4} fill="var(--teal-dk)" stroke="white" strokeWidth="2"
            onMouseMove={e => { const r = e.currentTarget.closest("svg").getBoundingClientRect(); setTooltip({ x: e.clientX-r.left, y: e.clientY-r.top, ...d }); }}
            onMouseLeave={() => setTooltip(null)} style={{ cursor: "pointer" }}
          />
        ))}
        {months.map((m, i) => (
          <text key={m} x={xBar(i)+bW/2} y={H-6} fill="var(--text4)" fontSize="9" textAnchor="middle" fontFamily="Inter" fontWeight="500">{m}</text>
        ))}
      </svg>
      <div className="row" style={{ gap: 18, marginTop: 8, justifyContent: "center" }}>
        <div className="row" style={{ gap: 6 }}><div style={{ width: 10, height: 10, borderRadius: 3, background: "var(--blue)", opacity: .5 }} /><span className="text-xs text-muted">Monthly Deposit</span></div>
        <div className="row" style={{ gap: 6 }}><div style={{ width: 14, height: 2, borderRadius: 2, background: "var(--teal)" }} /><span className="text-xs text-muted">Balance Growth</span></div>
      </div>
    </div>
  );
}

