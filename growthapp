function AuthPage({ onAuth }) {
  const [mode, setMode] = useState("login");
  const [form, setForm] = useState({ fullName: "", email: "", phone: "", password: "", goal: "" });
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");
  const [tempUser, setTempUser] = useState(null);
  const upd = k => e => setForm(f => ({ ...f, [k]: e.target.value }));

  const handleLogin = async () => {
    if (!form.email || !form.password) { setError("Email and password required"); return; }
    setLoading(true); setError("");
    const { data, error: err } = await sb.auth.signIn({ email: form.email, password: form.password });
    setLoading(false);
    if (err) { setError(err.message); return; }
    onAuth(data.user || DEMO_USER);
  };

  const handleSignup = async () => {
    if (!form.fullName || !form.email || !form.phone || !form.password) { setError("All fields required"); return; }
    setLoading(true); setError("");
    const { data, error: err } = await sb.auth.signUp({ email: form.email, password: form.password, options: { data: { full_name: form.fullName, phone: form.phone } } });
    setLoading(false);
    if (err) { setError(err.message); return; }
    setTempUser(data.user || { ...DEMO_USER, email: form.email, user_metadata: { full_name: form.fullName, phone: form.phone } });
    setMode("goal");
  };

  const handleGoal = () => {
    const g = Number(form.goal);
    if (!g || g < 1000) { setError("Enter a goal of at least R1,000"); return; }
    onAuth({ ...(tempUser || DEMO_USER), user_metadata: { ...tempUser?.user_metadata, goal: g } });
  };

  return (
    <div className="auth-wrap">
      {mode === "goal" ? (
        <div className="auth-card">
          <div className="auth-logo"><Icon name="goal" size={26} color="white" strokeWidth={1.8} /></div>
          <div className="auth-title">Set Your Goal</div>
          <div className="auth-sub">How much do you want by December 15, 2026?</div>
          {error && <div className="error-box">{error}</div>}
          <div className="input-group">
            <label className="input-label">Target Amount (ZAR)</label>
            <input className="input" type="number" placeholder="e.g. 25000" value={form.goal} onChange={upd("goal")} />
          </div>
          <button className="btn btn-primary btn-wide" onClick={handleGoal}>Get Started</button>
        </div>
      ) : (
        <div className="auth-card">
          <div className="auth-logo"><Icon name="tree" size={26} color="white" strokeWidth={1.8} /></div>
          <div className="auth-title">{mode === "login" ? "Welcome back" : "Create account"}</div>
          <div className="auth-sub">{mode === "login" ? "Sign in to your holiday savings" : "Start your investment journey"}</div>
          {error && <div className="error-box">{error}</div>}
          {mode === "signup" && <>
            <div className="input-group">
              <label className="input-label">Full Name</label>
              <input className="input" type="text" placeholder="Your full name" value={form.fullName} onChange={upd("fullName")} />
            </div>
            <div className="input-group">
              <label className="input-label">Phone Number</label>
              <input className="input" type="tel" placeholder="+27 82 000 0000" value={form.phone} onChange={upd("phone")} />
            </div>
          </>}
          <div className="input-group">
            <label className="input-label">Email</label>
            <input className="input" type="email" placeholder="you@example.com" value={form.email} onChange={upd("email")} />
          </div>
          <div className="input-group" style={{ marginBottom: 22 }}>
            <label className="input-label">Password</label>
            <input className="input" type="password" placeholder="••••••••" value={form.password} onChange={upd("password")} />
          </div>
          <button className="btn btn-primary btn-wide" onClick={mode === "login" ? handleLogin : handleSignup} disabled={loading}>
            {loading ? <span className="spinner"><Icon name="clock" size={16} color="white" /></span> : mode === "login" ? "Sign In" : "Create Account"}
          </button>
          <div style={{ marginTop: 10 }}>
            <button className="btn btn-wide" style={{ background: "var(--bg2)", color: "var(--text2)" }} onClick={() => onAuth(DEMO_USER)}>
              Try Demo
            </button>
          </div>
          <div className="auth-switch">
            {mode === "login" ? <>No account? <span onClick={() => { setMode("signup"); setError(""); }}>Sign up</span></> : <>Have an account? <span onClick={() => { setMode("login"); setError(""); }}>Sign in</span></>}
          </div>
        </div>
      )}
    </div>
  );
}

