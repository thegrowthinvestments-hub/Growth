// ── Donut Chart SVG component ─────────────────────────────────────────────────
function DonutChart({ segments, size = 110, thickness = 22, centerLabel, centerSub }) {
  const r = (size - thickness) / 2;
  const circ = 2 * Math.PI * r;
  const total = segments.reduce((s, x) => s + x.value, 0);
  let offset = 0;
  const slices = segments.map(seg => {
    const pct = seg.value / total;
    const dash = pct * circ;
    const gap = circ - dash;
    const slice = { ...seg, dash, gap, offset: offset * circ };
    offset += pct;
    return slice;
  });
  return (
    <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} style={{ display:"block" }}>
      <circle cx={size/2} cy={size/2} r={r} fill="none" stroke="var(--bg2)" strokeWidth={thickness} />
      {slices.map((s, i) => (
        <circle key={i} cx={size/2} cy={size/2} r={r} fill="none"
          stroke={s.color} strokeWidth={thickness}
          strokeDasharray={`${s.dash} ${s.gap}`}
          strokeDashoffset={-s.offset + circ * 0.25}
          strokeLinecap="round"
          style={{ transition: "stroke-dasharray 0.8s ease" }}
        />
      ))}
      {centerLabel && <>
        <text x={size/2} y={size/2 - 4} textAnchor="middle" fontSize="15" fontWeight="700" fill="var(--text1)" fontFamily="Inter,sans-serif">{centerLabel}</text>
        {centerSub && <text x={size/2} y={size/2 + 13} textAnchor="middle" fontSize="9" fill="var(--text3)" fontFamily="Inter,sans-serif">{centerSub}</text>}
      </>}
    </svg>
  );
}

// ── Bar Chart (Sales Dynamics style) ──────────────────────────────────────────
function BarDynamicsChart({ data, darkMode }) {
  const [hovered, setHovered] = useState(null);
  const W = 620, H = 180, PL = 44, PR = 12, PT = 12, PB = 28;
  const iW = W - PL - PR, iH = H - PT - PB;
  const maxVal = Math.max(...data.map(d => d.value));
  const yLines = [0, 0.25, 0.5, 0.75, 1];
  const barW = iW / data.length * 0.55;
  const xBar = i => PL + (i + 0.5) / data.length * iW - barW / 2;
  const yBar = v => PT + iH - (v / maxVal) * iH;
  const barH = v => (v / maxVal) * iH;

  return (
    <svg viewBox={`0 0 ${W} ${H}`} style={{ width:"100%", overflow:"visible" }}>
      <defs>
        <linearGradient id="barBlue" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor="#4f8ef7" />
          <stop offset="100%" stopColor="#a8c4fb" stopOpacity="0.6" />
        </linearGradient>
        <linearGradient id="barBlueHov" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor="#2563eb" />
          <stop offset="100%" stopColor="#60a5fa" />
        </linearGradient>
      </defs>
      {yLines.map(t => {
        const y = PT + iH * (1 - t);
        return <g key={t}>
          <line x1={PL} y1={y} x2={W - PR} y2={y} stroke={darkMode ? "rgba(255,255,255,0.06)" : "rgba(0,0,0,0.06)"} strokeWidth="1" />
          <text x={PL - 6} y={y + 4} fill={darkMode ? "#666" : "var(--text4)"} fontSize="9" textAnchor="end" fontFamily="Inter" fontWeight="500">
            {maxVal * t >= 1000 ? `${Math.round(maxVal * t / 1000)}k` : Math.round(maxVal * t)}
          </text>
        </g>;
      })}
      {data.map((d, i) => {
        const isHov = hovered === i;
        return (
          <g key={i} onMouseEnter={() => setHovered(i)} onMouseLeave={() => setHovered(null)} style={{ cursor:"pointer" }}>
            <rect x={xBar(i)} y={yBar(d.value)} width={barW} height={barH(d.value)}
              rx={4} fill={isHov ? "url(#barBlueHov)" : "url(#barBlue)"} />
            {isHov && (
              <g>
                <rect x={xBar(i) - 10} y={yBar(d.value) - 28} width={barW + 20} height={22} rx={5}
                  fill={darkMode ? "#2a2a3a" : "white"} stroke={darkMode ? "#444" : "var(--divider)"} strokeWidth="1" />
                <text x={xBar(i) + barW/2} y={yBar(d.value) - 12} textAnchor="middle" fontSize="10" fontWeight="700"
                  fill={darkMode ? "white" : "var(--text1)"} fontFamily="Inter">{fmt(d.value)}</text>
              </g>
            )}
            <text x={xBar(i) + barW/2} y={H - 6} fill={darkMode ? "#555" : "var(--text4)"} fontSize="8.5" textAnchor="middle" fontFamily="Inter" fontWeight="500">{d.label}</text>
          </g>
        );
      })}
    </svg>
  );
}

// ── Curved Line Chart (Overall Activity style) ─────────────────────────────────
function CurvedLineChart({ data, color = "#9b59b6", darkMode }) {
  const [hovered, setHovered] = useState(null);
  const W = 620, H = 140, PL = 44, PR = 12, PT = 12, PB = 28;
  const iW = W - PL - PR, iH = H - PT - PB;
  const maxVal = Math.max(...data.map(d => d.value)) * 1.1;
  const xPos = i => PL + (i / (data.length - 1)) * iW;
  const yPos = v => PT + iH - (v / maxVal) * iH;

  // Build smooth bezier path
  const buildPath = (pts) => {
    if (pts.length < 2) return "";
    let d = `M ${pts[0].x},${pts[0].y}`;
    for (let i = 0; i < pts.length - 1; i++) {
      const cpx = (pts[i].x + pts[i+1].x) / 2;
      d += ` C ${cpx},${pts[i].y} ${cpx},${pts[i+1].y} ${pts[i+1].x},${pts[i+1].y}`;
    }
    return d;
  };
  const pts = data.map((d, i) => ({ x: xPos(i), y: yPos(d.value) }));
  const linePath = buildPath(pts);
  const areaPath = linePath + ` L ${pts[pts.length-1].x},${PT+iH} L ${pts[0].x},${PT+iH} Z`;
  const gradId = `lineGrad_${color.replace("#","")}`;

  return (
    <svg viewBox={`0 0 ${W} ${H}`} style={{ width:"100%", overflow:"visible" }}>
      <defs>
        <linearGradient id={gradId} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor={color} stopOpacity="0.22" />
          <stop offset="100%" stopColor={color} stopOpacity="0" />
        </linearGradient>
      </defs>
      {[0, 0.5, 1].map(t => {
        const y = PT + iH * (1 - t);
        return <g key={t}>
          <line x1={PL} y1={y} x2={W-PR} y2={y} stroke={darkMode ? "rgba(255,255,255,0.05)" : "rgba(0,0,0,0.05)"} strokeWidth="1" strokeDasharray="3 3" />
          <text x={PL-6} y={y+4} fill={darkMode ? "#555" : "var(--text4)"} fontSize="9" textAnchor="end" fontFamily="Inter">
            {maxVal * t >= 1000 ? `${Math.round(maxVal*t/1000)}k` : Math.round(maxVal*t)}
          </text>
        </g>;
      })}
      <path d={areaPath} fill={`url(#${gradId})`} />
      <path d={linePath} fill="none" stroke={color} strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" />
      {data.map((d, i) => (
        <g key={i} onMouseEnter={() => setHovered(i)} onMouseLeave={() => setHovered(null)} style={{ cursor:"pointer" }}>
          <circle cx={xPos(i)} cy={yPos(d.value)} r={hovered===i ? 6 : 4}
            fill={hovered===i ? color : "white"} stroke={color} strokeWidth="2"
            style={{ transition:"r 0.15s" }} />
          {hovered===i && (
            <g>
              <rect x={xPos(i)-28} y={yPos(d.value)-30} width={56} height={20} rx={5}
                fill={darkMode?"#2a2a3a":"white"} stroke={darkMode?"#444":"var(--divider)"} strokeWidth="1"/>
              <text x={xPos(i)} y={yPos(d.value)-15} textAnchor="middle" fontSize="10" fontWeight="700"
                fill={darkMode?"white":"var(--text1)"} fontFamily="Inter">{fmt(d.value)}</text>
            </g>
          )}
          <text x={xPos(i)} y={H-6} fill={darkMode?"#555":"var(--text4)"} fontSize="8.5" textAnchor="middle" fontFamily="Inter">{d.label}</text>
        </g>
      ))}
    </svg>
  );
}

