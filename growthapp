// MAIN APP
// ============================================================
export default function App() {
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(true);
  const [page, setPage] = useState("dashboard");
  const [payments, setPayments] = useState(DEMO_PAYMENTS);
  const [subscription, setSubscription] = useState(null);
  const [darkMode, setDarkMode] = useState(() => {
    try { return localStorage.getItem("hsa_dark") === "1"; } catch { return false; }
  });
  const { toasts, addToast, removeToast } = useToast();

  const toggleDark = () => setDarkMode(v => {
    const next = !v;
    try { localStorage.setItem("hsa_dark", next ? "1" : "0"); } catch {}
    return next;
  });

  useEffect(() => {
    const cached = sb.auth.getUser();
    if (cached) setUser(cached);
    const sub = loadSubscription();
    if (sub) setSubscription(sub);
    setLoading(false);
  }, []);

  const handleSubscribe = (sub) => {
    saveSubscription(sub);
    setSubscription(sub);
  };
  const handleCancelSub = () => {
    saveSubscription(null);
    setSubscription(null);
  };

  const handleLogout = () => { sb.auth.signOut(); setUser(null); setPage("dashboard"); };

  if (loading) return (
    <>
      <style>{CSS}</style>
      <div style={{ minHeight:"100vh", display:"flex", alignItems:"center", justifyContent:"center", background:"var(--bg2)", fontFamily:"Inter,sans-serif" }}>
        <div style={{ textAlign:"center" }}>
          <div style={{ display:"flex", justifyContent:"center", marginBottom:16 }}><Icon name="tree" size={48} color="var(--teal)" strokeWidth={1.4} /></div>
          <div style={{ fontSize:16, fontWeight:600, color:"var(--text1)" }}>Loading Holiday Savings</div>
          <div style={{ fontSize:13, color:"var(--text3)", marginTop:4 }}>Please wait...</div>
        </div>
      </div>
    </>
  );

  return (
    <>
      <style>{CSS}</style>
      {!user ? (
        <AuthPage onAuth={setUser} />
      ) : (
        <div className={`app${darkMode ? " dark" : ""}`} style={{ background: darkMode ? "#0f0f1a" : "var(--bg2)", minHeight:"100vh", transition:"background 0.3s" }}>
          {page==="dashboard"   && <DashboardPage user={user} payments={payments} subscription={subscription} onNav={setPage} darkMode={darkMode} />}
          {page==="invest"      && <InvestPage user={user} payments={payments} setPayments={setPayments} addToast={addToast} darkMode={darkMode} />}
          {page==="analytics"   && <AnalyticsPage user={user} payments={payments} darkMode={darkMode} toggleDark={toggleDark} />}
          {page==="leaderboard" && <LeaderboardPage darkMode={darkMode} />}
          {page==="withdraw"    && <WithdrawPage user={user} payments={payments} darkMode={darkMode} />}
          {page==="subscribe"   && <SubscribePage user={user} subscription={subscription} payments={payments} onSubscribe={handleSubscribe} onCancel={handleCancelSub} onNav={setPage} addToast={addToast} darkMode={darkMode} />}
          {page==="referral"    && <ReferralPage user={user} payments={payments} addToast={addToast} darkMode={darkMode} />}
          {page==="settings"    && <SettingsPage user={user} onLogout={handleLogout} darkMode={darkMode} toggleDark={toggleDark} />}
          {page==="admin"       && <AdminPage darkMode={darkMode} />}
          <FloatingNav active={page} onNav={setPage} isAdmin={user?.email?.includes("admin")} darkMode={darkMode} />
        </div>
      )}
      <ToastContainer toasts={toasts} onClose={removeToast} />
    </>
  );
}