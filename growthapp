// Returns which calendar months (0-11) have a payment due since subscription start
const getMonthsDue = (sub) => {
  if (!sub) return [];
  const start = new Date(sub.startDate);
  const now = new Date();
  const months = [];
  let d = new Date(start.getFullYear(), start.getMonth(), 1);
  while (d <= now && d.getMonth() <= 11) {
    months.push({ year: d.getFullYear(), month: d.getMonth() });
    d = new Date(d.getFullYear(), d.getMonth() + 1, 1);
  }
  return months;
};

