function SubscribePage({ user, subscription, payments, onSubscribe, onCancel, onNav, addToast }) {
  const [step, setStep] = useState(subscription ? "manage" : "pick");
  const [selectedLink, setSelectedLink] = useState(null);
  const tiers = [...new Set(YOCO_LINKS.map(l => l.tier))];

  const handleConfirm = () => {
    if (!selectedLink) return;
    const sub = {
      amount: selectedLink.amount,
      tier: selectedLink.tier,
      growth: selectedLink.growth,
      url: selectedLink.url,
      label: selectedLink.label,
      startDate: new Date().toISOString(),
      dayOfMonth: 1,
    };
    onSubscribe(sub);
    addToast({ type: "success", title: "Subscription active!", message: `${fmt(selectedLink.amount)}/month plan started. Pay each month via Yoco.` });
    setStep("manage");
  };

  const handleCancel = () => {
    onCancel();
    addToast({ type: "info", title: "Subscription cancelled", message: "You can re-subscribe at any time." });
    setStep("pick");
  };

  // Build monthly timeline
  const buildTimeline = () => {
    if (!subscription) return [];
    const due = getMonthsDue(subscription);
    return due.map(({ month, year }) => {
      const paid = payments.some(p => p.status === "success" && p.month === MONTH_NAMES[month] && new Date(p.created_at).getFullYear() === year);
      const isCurrent = month === new Date().getMonth() && year === new Date().getFullYear();
      const isFuture = new Date(year, month, 1) > new Date();
      return { month, year, paid, isCurrent, isFuture, name: MONTH_NAMES[month] };
    });
  };

  if (step === "manage" && subscription) {
    const timeline = buildTimeline();
    const paidCount = timeline.filter(t => t.paid).length;
    const missedCount = timeline.filter(t => !t.paid && !t.isCurrent && !t.isFuture).length;
    const link = YOCO_LINKS.find(l => l.amount === subscription.amount);
    const currentEntry = timeline.find(t => t.isCurrent);
    const paidThisMonth = currentEntry?.paid;

    return (
      <div className="page">
        <div className="page-header">
          <div><div className="page-title">My Subscription</div><div className="page-sub">Monthly savings plan</div></div>
          <button className="btn btn-sm" style={{ background:"rgba(255,59,48,0.08)", color:"var(--red)" }} onClick={handleCancel}>
            <Icon name="xmark" size={13} strokeWidth={2.2} />Cancel Plan
          </button>
        </div>

        {/* Active plan card */}
        <div className="sub-card" style={{ marginBottom:16 }}>
          <div style={{ display:"flex", alignItems:"center", gap:14, marginBottom:16 }}>
            <div style={{ width:52,height:52,borderRadius:16,background:"var(--teal-lt)",display:"flex",alignItems:"center",justifyContent:"center" }}>
              <Icon name="repeat" size={24} color="var(--teal-dk)" strokeWidth={1.7} />
            </div>
            <div className="flex-1">
              <div style={{ fontSize:20, fontWeight:700, letterSpacing:"-0.3px" }}>{fmt(subscription.amount)}<span style={{ fontSize:14, fontWeight:500, color:"var(--text3)" }}> / month</span></div>
              <div style={{ fontSize:13, color:"var(--text3)", marginTop:2 }}>{subscription.tier} · {subscription.growth}% growth · started {new Date(subscription.startDate).toLocaleDateString("en-ZA",{month:"short",year:"numeric"})}</div>
            </div>
            <StatusBadge status="success" />
          </div>
          <div style={{ display:"grid", gridTemplateColumns:"repeat(3,1fr)", gap:10, marginBottom:16 }}>
            {[
              { label:"Paid", value:paidCount, color:"var(--green)" },
              { label:"Missed", value:missedCount, color: missedCount > 0 ? "var(--red)" : "var(--text3)" },
              { label:"Remaining", value: Math.max(0, 12 - new Date().getMonth() - paidCount), color:"var(--teal-dk)" },
            ].map(s => (
              <div key={s.label} className="card-inset" style={{ textAlign:"center" }}>
                <div style={{ fontSize:22, fontWeight:700, color:s.color }}>{s.value}</div>
                <div className="text-xs text-muted">{s.label}</div>
              </div>
